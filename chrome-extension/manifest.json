{
  "manifest_version": 3,
  "name": "レインズ照合ツール",
  "version": "1.0.0",
  "description": "レインズ検索結果を照合アプリへ送信します",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://*/*", "http://localhost:*/"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "レインズ照合ツール"
  },
  "options_page": "options.html"
}
